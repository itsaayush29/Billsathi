# Frontend environment variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (.env.local)
NEXT_PUBLIC_API_URL=/backend-api
BACKEND_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (set these in Vercel dashboard > your project > Settings > Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────
#
# BACKEND_API_URL = https://billsathi-backend-production.up.railway.app/api
#   ^ This is the server-side rewrite target. Vercel's edge forwards
#     browser requests from /backend-api/* to this URL. Required.
#
# NEXT_PUBLIC_APP_URL = https://billsathi.vercel.app
#   ^ Your public frontend URL.
#
# DO NOT set NEXT_PUBLIC_API_URL in production — the default "/backend-api"
# is correct and keeps all browser requests same-origin (no CORS needed).
