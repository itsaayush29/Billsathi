generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PRO
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  plan         UserPlan  @default(FREE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customers    Customer[]
  invoices     Invoice[]
  payments     Payment[]

  @@index([role])
  @@index([plan])
}

model Customer {
  id        String    @id @default(cuid())
  userId    String
  name      String
  phone     String?
  email     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([userId, createdAt])
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  customerId  String?
  amount      Decimal       @db.Decimal(10, 2)
  status      InvoiceStatus @default(DRAFT)
  invoiceDate DateTime
  items       Json
  pdfFileKey  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([customerId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  amount            Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(PENDING)
  provider          String
  providerOrderId   String?
  providerPaymentId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}
